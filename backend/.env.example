PORT=3001
DATABASE_URL=postgres://user:pass@localhost:5432/chatapp
JWT_SECRET=change_me_32_chars_minimum_random
JWT_REFRESH_SECRET=change_me_different_32_chars_random
STRIPE_SECRET_KEY=sk_test_or_sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=price_1TPIHFIje3Yf3KsC7LL4sRsP
STRIPE_YEARLY_PRICE_ID=price_1TaBPgIje3Yf3KsCjzbuYoQj
FRONTEND_URL=http://localhost:5173
# Public backend URL used to build OAuth callback URLs when per-platform redirect URIs are omitted
BACKEND_URL=http://localhost:3001
NODE_ENV=development

# ── Social OAuth (optional) ───────────────────────────────────────────────────
# Callback URLs are served at /api/social/{platform}/callback (Twitter uses /api/social/x/callback).
# Nginx must proxy /api/ to the backend — /connect/ paths will NOT work on production.
# Each redirect URI must match EXACTLY in the provider dashboard — including http/https and trailing slashes.
#
# If you set BACKEND_URL, defaults are:
#   Facebook:   {BACKEND_URL}/api/social/facebook/callback
#   Instagram:  {BACKEND_URL}/api/social/instagram/callback
#   Twitter/X:  {BACKEND_URL}/api/social/x/callback
#   YouTube:    {BACKEND_URL}/api/social/youtube/callback
#   Twitch:     {BACKEND_URL}/api/social/twitch/callback
#   Kick:       {BACKEND_URL}/api/social/kick/callback
#
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI=
#
# Instagram: use the Instagram App ID & Secret from Meta → Instagram → API setup with Instagram login
# (NOT the main Facebook App ID). Scope: instagram_business_basic. Account must be Creator/Business.
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# INSTAGRAM_REDIRECT_URI=
#
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=https://your-domain.com/api/social/x/callback
# TWITTER_SCOPE=users.read offline.access
#
# X (Twitter) Developer Portal setup (https://developer.x.com):
# 1. Open your app → User authentication settings → Set up / Edit
# 2. Type of App: Web App, Automated App or Bot (confidential — uses Client Secret)
# 3. Callback URI / Redirect URL (must match TWITTER_REDIRECT_URI exactly):
#      https://your-domain.com/api/social/x/callback
# 4. Website URL: https://your-domain.com
# 5. Enable OAuth 2.0 scopes: users.read and offline.access
#    (tweet.read is NOT required for profile linking — disable it if you see auth errors)
# 6. Use the OAuth 2.0 Client ID and Client Secret — NOT the API Key / API Secret
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# Enable YouTube Data API v3 in Google Cloud Console.
#
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_REDIRECT_URI=
#
# KICK_CLIENT_ID=
# KICK_CLIENT_SECRET=
# KICK_REDIRECT_URI=
